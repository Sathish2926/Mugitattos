# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/mugitattoo

# JWT / Admin Setup
JWT_SECRET=change_me_super_secret
ADMIN_SETUP_TOKEN=one_time_setup_token

# Admin seeding (optional; used by npm run seed:admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongPass123

# ==============================================
# EMAIL CONFIGURATION (Required for notifications)
# ==============================================

# Gmail SMTP (Recommended for testing):
# 1. Enable 2-Step Verification in your Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character password below

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here
EMAIL_FROM=Mugi Tattoos <your-email@gmail.com>

# Other SMTP Providers:
# - SendGrid: smtp.sendgrid.net (Port: 587)
# - Mailgun: smtp.mailgun.org (Port: 587)
# - AWS SES: email-smtp.region.amazonaws.com (Port: 587)

# ==============================================
# WHATSAPP CONFIGURATION (Choose ONE option)
# ==============================================

# Option 1: Twilio WhatsApp (Easier setup, good for testing)
# Sign up: https://www.twilio.com/try-twilio
# Get sandbox credentials from Console > Messaging > Try WhatsApp
# Note: Users must opt-in by sending "join <sandbox-name>" to Twilio number

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+14155238886

# Option 2: WhatsApp Business Cloud API (Production-ready)
# Setup: https://developers.facebook.com/apps
# Create Business app > Add WhatsApp > Get credentials

# WHATSAPP_API_TOKEN=EAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WHATSAPP_PHONE_NUMBER_ID=123456789012345

# ==============================================
# SETUP INSTRUCTIONS
# ==============================================

# 1. Copy this file to .env: cp .env.example .env
# 2. Update all credentials above
# 3. Update studio address in:
#    - src/services/emailService.js (lines ~40, ~90)
#    - src/services/whatsappService.js (lines ~75, ~100)
# 4. Test by confirming a booking from admin panel

# ==============================================
# TESTING NOTIFICATIONS
# ==============================================

# 1. Start server: npm run dev
# 2. Start client: cd client && npm run dev
# 3. Create test booking from booking page
# 4. Login to admin panel
# 5. Confirm the booking
# 6. Check email inbox and WhatsApp for notifications

